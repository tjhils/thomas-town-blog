---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  minutesRead: string;
}

const { title, description, date, tags, minutesRead } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const isoDate = date.toISOString();
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": isoDate,
  "author": {
    "@type": "Person",
    "name": "Thomas Hils",
    "url": "https://thomas.town"
  },
  "publisher": {
    "@type": "Person",
    "name": "Thomas Hils",
    "url": "https://thomas.town"
  },
  "url": canonicalURL.href,
  "keywords": tags.join(", "),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL.href
  }
};
---

<Base title={`${title} - blog.thomas.town`} description={description} ogType="article" publishedDate={isoDate}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <main class="container">
    <div class="post-header">
      <a href="/" class="post-header__back">&larr; cd ~/blog</a>
      <h1 class="post-header__title">{title}</h1>
      <div class="post-header__meta">
        <span>{formattedDate}</span>
        <span>{minutesRead}</span>
        {tags.length > 0 && (
          <div class="post-card__tags">
            {tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>
    <article class="prose">
      <slot />
    </article>
  </main>
</Base>
